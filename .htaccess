<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloqueia acesso a arquivos sensíveis
    <FilesMatch "^(\.env|\.git|composer\.(json|lock)|package(-lock)?\.json|artisan|phpunit\.xml|vite\.config\.js)$">
        Require all denied
    </FilesMatch>

    # Bloqueia acesso direto a diretórios internos do Laravel
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/.*)?$ - [F,L]

    # Encaminha todas as requisições para a pasta public
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>
